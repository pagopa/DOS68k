# Auth provider selection: "aws" or "local".
# See README.AUTH_PROVIDERS.md for what each provider requires.
export AUTH_PROVIDER=local

# AWS Cognito Configuration (only used when AUTH_PROVIDER=aws).
# The values below target LocalStack; replace with real AWS settings for production.
export AWS_REGION=us-east-1
export AWS_ENDPOINT_URL=http://localstack:4566
export AWS_ACCESS_KEY_ID=test
export AWS_SECRET_ACCESS_KEY=test
export AWS_COGNITO_USERPOOL_ID=local-userpool-id
export ENVIRONMENT=test  # "test" → fetch JWKS from AWS_ENDPOINT_URL; anything else → real AWS
