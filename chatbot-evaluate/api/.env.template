export FRONTEND_URL=http://localhost # URL of the frontend application, used for CORS

# ---------------------------------------------------------------------------
# Queue (Redis)
# ---------------------------------------------------------------------------
# Evaluation runs on its OWN queue, separate from document indexing. It uses a
# distinct stream/group (evaluate-stream / evaluate-group) so evaluation jobs
# never mix with indexing jobs. The API and the WORKER must use the same
# provider, stream and group.
export QUEUE_PROVIDER=redis # Supported values: "redis" | "sqs"
export REDIS_HOST=redis-queue # Hostname of the Redis instance
export REDIS_PORT=6379 # Port of the Redis instance
export REDIS_STREAM=evaluate-stream # Redis stream name (must match the worker)
export REDIS_GROUP=evaluate-group # Redis consumer group name (must match the worker)

# ---------------------------------------------------------------------------
# Database (NoSQL — DynamoDB via LocalStack)
# ---------------------------------------------------------------------------
# Feedback and evaluation results are read from / written to the same `queries`
# table that chatbot-api writes. Point this at the SAME NoSQL instance.
export NOSQL_PROVIDER=dynamodb
export DYNAMODB_ENDPOINT_URL=http://localstack # Hostname of the DynamoDB service
export DYNAMODB_PORT=4566 # Port number of the DynamoDB service
export DYNAMODB_REGION=us-east-1 # Region of the DynamoDB service
export AWS_ACCESS_KEY_ID=test # Access key ID for the DynamoDB service
export AWS_SECRET_ACCESS_KEY=test # Secret access key for the DynamoDB service

export QUERY_TABLENAME=queries # Table name for queries (defaults to "queries")

# ---------------------------------------------------------------------------
# Evaluation
# ---------------------------------------------------------------------------
export EVALUATE_UPPER_LIMIT=50 # Max queries evaluated per "evaluate all" request (defaults to 50)

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
export LOG_LEVEL=20 # Python logging level: 10=DEBUG, 20=INFO, 30=WARNING
