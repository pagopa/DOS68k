export FRONTEND_URL=http://localhost # URL of the frontend application, used for CORS

# ---------------------------------------------------------------------------
# Database (NoSQL — DynamoDB via LocalStack)
# ---------------------------------------------------------------------------
export NOSQL_PROVIDER=dynamodb

export DYNAMODB_ENDPOINT_URL=http://localstack # Hostname of the DynamoDB service
export DYNAMODB_PORT=4566 # Port number of the DynamoDB service
export DYNAMODB_REGION=us-east-1 # Region of the DynamoDB service
export AWS_ACCESS_KEY_ID=test # Access key ID for the DynamoDB service
export AWS_SECRET_ACCESS_KEY=test # Secret access key for the DynamoDB service

# ---------------------------------------------------------------------------
# Session
# ---------------------------------------------------------------------------
export SESSION_EXPIRATION_DAYS=90 # Number of days after which a session expires

# ---------------------------------------------------------------------------
# PII Masking
# ---------------------------------------------------------------------------
export MASK_PII=true # Whether to mask PII in user questions and answers before storing them
export MASKING_SERVICE_URL=http://localhost:3000 # URL of the masking service

# ---------------------------------------------------------------------------
# Redis (vector store — shared with chatbot-index)
# ---------------------------------------------------------------------------
export REDIS_HOST=localhost # Hostname of the Redis instance
export REDIS_PORT=6379 # Port of the Redis instance

# ---------------------------------------------------------------------------
# Chatbot — general
# ---------------------------------------------------------------------------
export CHATBOT_RELEASE=0.1.0 # Release tag appended to every response in the "products" field
export LOG_LEVEL=20 # Python logging level: 10=DEBUG, 20=INFO, 30=WARNING

# ---------------------------------------------------------------------------
# Chatbot — vector index IDs (must match the IDs used by chatbot-index)
# ---------------------------------------------------------------------------
export DEVPORTAL_INDEX_ID=devportal # mock — replace with the actual Redis index name used during indexing
export CITTADINO_INDEX_ID=cittadino # mock — replace with the actual Redis index name used during indexing

# ---------------------------------------------------------------------------
# Chatbot — LLM and Embedding provider
# ---------------------------------------------------------------------------
export PROVIDER=google # Supported values: "google" | "mock"
export GOOGLE_API_KEY=your-google-api-key # mock — replace with a valid Google AI Studio or Vertex AI API key

# LLM
export MODEL_ID=gemini-2.0-flash # mock — replace with the target Gemini model ID
export TEMPERATURE_RAG=0.1 # Temperature for RAG query engine (0.0–1.0)
export TEMPERATURE_AGENT=0.0 # Temperature for the discovery agent (0.0 = deterministic)
export MAX_TOKENS=1024 # Maximum number of tokens to generate per LLM response

# Embedding
export EMBED_MODEL_ID=text-embedding-004 # mock — replace with the target Gemini embedding model ID
export EMBED_DIM=768 # Output dimensionality (must match the value used during indexing)
export EMBED_BATCH_SIZE=100 # Number of texts to embed in a single API call
export EMBED_TASK=RETRIEVAL_QUERY # Embedding task type: RETRIEVAL_QUERY | RETRIEVAL_DOCUMENT | SEMANTIC_SIMILARITY
export EMBED_RETRIES=3 # Number of retry attempts on embedding API errors
export EMBED_RETRY_MIN_SECONDS=1.0 # Minimum wait time (seconds) between retries

# ---------------------------------------------------------------------------
# Chatbot — retrieval
# ---------------------------------------------------------------------------
export SIMILARITY_TOPK=5 # Number of top chunks to retrieve from the vector store
export USE_ASYNC=true # Whether to run the query engine asynchronously

# Chunk settings — must match the values used by chatbot-index during document ingestion
export CHUNK_SIZE=512
export CHUNK_OVERLAP=50

# ---------------------------------------------------------------------------
# Chatbot — prompt templates
# (multi-line values: use \n for newlines or mount as files and reference the path)
# ---------------------------------------------------------------------------
export QA_PROMPT_STR="Context: {context_str}\n\nQuestion: {query_str}\n\nAnswer:" # mock — replace with the actual QA prompt
export REFINE_PROMPT_STR="Existing answer: {existing_answer}\n\nAdditional context: {context_msg}\n\nRefined answer:" # mock — replace with the actual refine prompt

# ---------------------------------------------------------------------------
# Chatbot — agent system prompts
# ---------------------------------------------------------------------------
export DISCOVERY_SYSTEM_PROMPT_STR="You are a helpful assistant for PagoPA services." # mock — replace with the actual discovery agent system prompt
export REACT_SYSTEM_STR="You are a ReAct agent. Use the available tools to answer the user question." # mock — replace with the actual ReAct system header