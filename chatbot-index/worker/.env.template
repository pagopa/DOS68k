# Queue configuration
export QUEUE_PROVIDER=sqs # Queue backend: sqs or redis
export SQS_ENDPOINT_URL=http://localstack # SQS endpoint URL
export SQS_PORT=4566 # SQS port
export SQS_REGION=us-east-1 # SQS region
export AWS_ACCESS_KEY_ID=test # AWS access key
export AWS_SECRET_ACCESS_KEY=test # AWS secret key
export SQS_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/my-queue.fifo # Full SQS queue URL
export SQS_QUEUE_NAME=my-queue.fifo # SQS queue name

# Storage configuration
export STORAGE_PROVIDER=minio # Storage backend: aws_s3 or minio
export INDEX_DOCUMENTS_BUCKET_NAME=documents # Object storage bucket for uploaded documents
export MINIO_ENDPOINT=storage # MinIO endpoint hostname
export MINIO_PORT=9000 # MinIO port
export MINIO_ACCESS_KEY=minioadmin # MinIO access key
export MINIO_SECRET_KEY=minioadmin # MinIO secret key
export MINIO_REGION=us-east-1 # MinIO region
export MINIO_SECURE=false # Use HTTPS: true or false

# Vector DB configuration
export VECTOR_DB_PROVIDER=redis # Vector DB backend: redis or qdrant
export REDIS_HOST=vector-db # Redis hostname
export REDIS_PORT=6379 # Redis port

# Embedding configuration
export PROVIDER=google # Embedding provider: google
export MODEL_API_KEY=your-api-key # API key for the embedding provider
export EMBED_MODEL_ID=text-embedding-004 # Embedding model ID
export EMBED_CHUNK_SIZE=256 # Chunk size in tokens
export EMBED_CHUNK_OVERLAP=20 # Overlapping tokens between chunks
export EMBED_DIM=768 # Vector dimension (must match vector DB index)
export EMBED_BATCH_SIZE=100 # Chunks embedded per API call
export EMBED_TASK=RETRIEVAL_DOCUMENT # Embedding task type
export EMBED_RETRIES=3 # Retry attempts on API failure
export EMBED_RETRY_MIN_SECONDS=1.0 # Minimum wait between retries

# Logging
export LOG_LEVEL=20 # Python logging level: 10=DEBUG, 20=INFO, 30=WARNING