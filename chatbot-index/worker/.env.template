# Queue configuration
# Must match the chatbot-index API: same provider, stream and group, on the
# same Redis instance. REDIS_HOST/REDIS_PORT are shared with the Vector DB
# section below (both run on redis-vdb under compose).
export QUEUE_PROVIDER=redis # Queue backend: redis or sqs
export REDIS_STREAM=my-stream # Redis stream name (must match the API)
export REDIS_GROUP=my-group # Redis consumer group name (must match the API)

# --- Alternative: SQS (e.g., via LocalStack for local dev or real AWS SQS) ---
# export QUEUE_PROVIDER=sqs
# export SQS_ENDPOINT_URL=http://localstack
# export SQS_PORT=4566
# export SQS_REGION=us-east-1
# export SQS_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/my-queue.fifo
# export SQS_QUEUE_NAME=my-queue.fifo
# export AWS_ACCESS_KEY_ID=test
# export AWS_SECRET_ACCESS_KEY=test

# Storage configuration
export STORAGE_PROVIDER=minio # Storage backend: aws_s3 or minio
export INDEX_DOCUMENTS_BUCKET_NAME=documents # Object storage bucket for uploaded documents. MUST match the API and the bucket created by the minio-init job in compose.yaml.
export MINIO_ENDPOINT=minio # MinIO endpoint hostname (matches the compose service name)
export MINIO_PORT=9000 # MinIO port
export MINIO_ACCESS_KEY=admin # MinIO access key (matches MINIO_ROOT_USER in ./.env.storage)
export MINIO_SECRET_KEY=minioadmin # MinIO secret key (matches MINIO_ROOT_PASSWORD in ./.env.storage)
export MINIO_REGION=us-east-1 # MinIO region
export MINIO_SECURE=false # Use HTTPS: true or false

# Vector DB configuration
export VECTOR_DB_PROVIDER=redis # Vector DB backend: redis or qdrant
export REDIS_HOST=redis-vdb # Redis hostname (matches the compose service name; use this when running redis-vdb under compose)
export REDIS_PORT=6379 # Redis port

# --- Alternative: Qdrant (matches the compose service used by chatbot-index-worker by default) ---
# export VECTOR_DB_PROVIDER=qdrant
# export QDRANT_HOST=qdrant
# export QDRANT_PORT=6333

# Embedding configuration
export PROVIDER=google # Embedding provider: google
export MODEL_API_KEY=your-api-key # API key for the embedding provider
export EMBED_MODEL_ID=text-embedding-004 # Embedding model ID
export EMBED_CHUNK_SIZE=256 # Chunk size in tokens
export EMBED_CHUNK_OVERLAP=20 # Overlapping tokens between chunks
export EMBED_DIM=768 # Vector dimension (must match vector DB index)
export EMBED_BATCH_SIZE=100 # Chunks embedded per API call
export EMBED_TASK=RETRIEVAL_DOCUMENT # Embedding task type
export EMBED_RETRIES=3 # Retry attempts on API failure
export EMBED_RETRY_MIN_SECONDS=1.0 # Minimum wait between retries

# Logging
export LOG_LEVEL=20 # Python logging level: 10=DEBUG, 20=INFO, 30=WARNING