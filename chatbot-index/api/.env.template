export FRONTEND_URL=http://localhost # URL of the frontend application, used for CORS

# These settings depend on how you configured your queue service (it could be within compose.yaml or external)
export QUEUE_PROVIDER=sqs

export SQS_ENDPOINT_URL=http://localstack # Hostname of the queue service
export SQS_PORT=4566 # Port of the queue service
export SQS_REGION=us-east-1 # Region of the queue service
export AWS_ACCESS_KEY_ID=test # Access key ID for the queue service
export AWS_SECRET_ACCESS_KEY=test # Secret access key for the queue service
export SQS_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/my-queue.fifo
export SQS_QUEUE_NAME=my-queue.fifo

# These settings depend on how you configured your object storage service (it could be within compose.yaml or external)
export STORAGE_PROVIDER=aws_s3

export S3_ENDPOINT=http://storage:9000 # Endpoint URL of the S3-compatible storage service. If using AWS S3, you can leave this blank.
export BUCKET_NAME=chatbot-index # Name of the S3 bucket to use. Make sure it exists when interacting with it
export AWS_ACCESS_KEY_ID=admin
export AWS_SECRET_ACCESS_KEY=minioadmin
export S3_REGION=us-east-1

# ---------------------------------------------------------------------------
# Chatbot — LLM and Embedding provider
# ---------------------------------------------------------------------------
export PROVIDER=google # Supported values: "google" | "mock"
export GOOGLE_API_KEY=your-google-api-key # mock — replace with a valid Google AI Studio or Vertex AI API key

# Embedding
export EMBED_MODEL_ID=text-embedding-004 # mock — replace with the target Gemini embedding model ID
export EMBED_DIM=768 # Output dimensionality (must match the value used during indexing)
export EMBED_BATCH_SIZE=100 # Number of texts to embed in a single API call
export EMBED_TASK=RETRIEVAL_QUERY # Embedding task type: RETRIEVAL_QUERY | RETRIEVAL_DOCUMENT | SEMANTIC_SIMILARITY
export EMBED_RETRIES=3 # Number of retry attempts on embedding API errors
export EMBED_RETRY_MIN_SECONDS=1.0 # Minimum wait time (seconds) between retries